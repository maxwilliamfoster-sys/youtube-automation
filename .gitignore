# ─── Secrets & credentials — NEVER upload these ───────────────────────────────
.env
token.json
client_secrets.json
tiktok_cookies.txt
tiktok_cookies.json
tiktok_tokens.json

# ─── Persistent stealth browser profile — contains your live TikTok session ───
tiktok_profile/

# ─── Generated output — large, per-video files ────────────────────────────────
output/
audio/
scene_images/

# ─── Downloaded assets — large, auto-downloaded on first run ──────────────────
music/
kokoro_models/
assets/MontserratBold.ttf
assets/arialbd.ttf

# ─── Gameplay clips — large video files ───────────────────────────────────────
gameplay/vertical_test_0.mp4
gameplay/vertical_test_1.mp4
gameplay/subway_3.mp4
gameplay/_pexels_fresh_*.mp4
.last_clip
.last_search

# ─── Test artefacts ───────────────────────────────────────────────────────────
test_*.mp3
test_*.wav
generate_preview.py
debug/

# ─── Logs (local state, not needed in repo) ───────────────────────────────────
scheduler_log.txt
upload_log.txt
documentary_log.json

# Wikipedia case pool — a rebuildable cache, not source. Left uncommitted so CI
# refetches it and picks up newly-written articles. (recent_cases.json IS committed:
# it is the memory of what has already been posted.)
case_pool.json

# ─── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
